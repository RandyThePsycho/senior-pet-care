# Supabase 连接配置
# 在 Supabase 项目设置 > API 中获取。
NEXT_PUBLIC_SITE_URL=
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Optional launch analytics. Leave blank to keep console-only tracking.
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# Optional internal read-only dashboard. Do not expose this value publicly.
INTERNAL_DASHBOARD_TOKEN=

# 仅服务端使用！绝不可暴露给 client component / 浏览器。
# 用于 API route 内的写入与读取（绕过 RLS）。
SUPABASE_SERVICE_ROLE_KEY=

# MailerLite Phase 3：仅服务端使用，不能加 NEXT_PUBLIC_ 前缀。
MAILERLITE_API_KEY=
MAILERLITE_GROUP_ID=
